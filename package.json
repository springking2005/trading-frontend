{
  "name": "trading-platform-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test --project=chromium",
    "test:visual": "playwright test tests/e2e/specs/visual-trading-workbench.spec.ts --project=chromium",
    "verify": "npm run build && npm run test:e2e",
    "dev:h5": "vite --host 0.0.0.0",
    "build:h5": "npm run build",
    "preview:h5": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vue-tsc": "^2.0.0"
  }
}
